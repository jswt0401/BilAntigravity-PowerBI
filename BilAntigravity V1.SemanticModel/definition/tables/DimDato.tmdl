			lineageTag: f7cb1ab4-9b4f-4374-a2c1-ba7f3fdf4ce3
			column: Dag

	partition DimDato = m
		mode: import
		source =
				let
				  Kilde = #date(2020, 1, 1),
				  SlutDato = #date(2030, 12, 31),
				  AntalDage = Duration.Days(SlutDato - Kilde),
				  Datoer = List.Dates(Kilde, AntalDage, #duration(1, 0, 0, 0)),
				  Tabel = Table.FromList(Datoer, Splitter.SplitByNothing(), {"Dato"}),
				  TypeByttet = Table.TransformColumnTypes(Tabel, {{"Dato", type date}}),
				  TilfoejAar = Table.AddColumn(TypeByttet, "Aar", each Date.Year([Dato]), Int64.Type),
				  TilfoejMaaned = Table.AddColumn(TilfoejAar, "Maaned", each Date.Month([Dato]), Int64.Type),
				  TilfoejDag = Table.AddColumn(TilfoejMaaned, "Dag", each Date.Day([Dato]), Int64.Type),
				  TilfoejMaanedsTekst = Table.AddColumn(TilfoejDag, "MaanedNavn", each Text.Proper(Date.ToText([Dato], "MMMM")), type text),
				  TilfoejKvartal = Table.AddColumn(TilfoejMaanedsTekst, "Kvartal", each "Q" & Text.From(Number.RoundUp([Maaned]/3)), type text),
				  TilfoejUgeNr = Table.AddColumn(TilfoejKvartal, "UgeNr", each Date.WeekOfYear([Dato]), Int64.Type),
				    #"Tilføjet brugerdefineret" = Table.AddColumn(TilfoejUgeNr, "Brugerdefineret", each [Dag]),
				    #"Omdøbte kolonner" = Table.RenameColumns(#"Tilføjet brugerdefineret",{{"Brugerdefineret", "tester"}})
				in
				  #"Omdøbte kolonner"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

